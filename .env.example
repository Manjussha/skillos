# SkillOS provider configuration — copy to .env and fill in at least one.
# The Vercel AI SDK reads these. You only need keys for providers you use.
# Leave everything blank to run fully offline with the built-in mock provider.

# OpenRouter — one key unlocks many models (recommended first provider)
OPENROUTER_API_KEY=

# Direct providers (optional) — each is its own native endpoint
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# Ollama — local models, no key needed. Default endpoint shown.
OLLAMA_BASE_URL=http://localhost:11434/api

# Active provider selection. One of:
#   openai | anthropic | google | groq | deepseek | openrouter | ollama | mock
# If unset (or its key is missing), SkillOS auto-detects: the first provider
# above whose key is set, else ollama if OLLAMA_BASE_URL is set, else mock.
# /provider sets this live at runtime (writes it here).
SKILLOS_PROVIDER=

# Server
PORT=8787
