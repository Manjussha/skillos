# SkillOS provider configuration — copy to .env and fill in at least one.
# The Vercel AI SDK reads these. You only need keys for providers you use.
# Leave everything blank to run fully offline with the built-in mock provider.

# OpenRouter — one key unlocks many models (recommended first provider)
OPENROUTER_API_KEY=

# Direct providers (optional) — each is its own native endpoint
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# Ollama — local models, no key needed. Default endpoint shown.
OLLAMA_BASE_URL=http://localhost:11434/api

# Ollama Cloud — hosted open models via an OpenAI-compatible endpoint. Needs a
# key from ollama.com. Base URL is overridable (defaults to https://ollama.com/v1).
OLLAMA_API_KEY=
OLLAMA_CLOUD_URL=https://ollama.com/v1

# Active provider selection. One of:
#   openai | anthropic | google | groq | deepseek | openrouter | ollama |
#   ollama-cloud | mock
# OR an installed AI CLI tool (uses ITS own login, no SkillOS key):
#   claude-code | gemini | opencode | kilo-code
# If unset (or its key/binary is missing), SkillOS auto-detects: the first keyed
# provider above, else ollama if OLLAMA_BASE_URL is set, else mock.
# /provider sets this live at runtime (writes it here).
SKILLOS_PROVIDER=

# Optional: timeout (ms) for a CLI-as-provider turn. Default 120000.
# SKILLOS_CLI_TIMEOUT_MS=120000

# Server
PORT=8787
